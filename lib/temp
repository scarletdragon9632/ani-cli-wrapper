    if date --version 2>/dev/null | grep -q GNU; then
        date -d "@${timestamp}" "+%Y-%m-%d %H:%M" 2>/dev/null || echo "Unknown"
    elif date -r "$timestamp" "+%Y-%m-%d %H:%M" 2>/dev/null; then
